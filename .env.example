# Application
APP_NAME=ToxScreen
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-random-string-64-chars

# Database
DATABASE_URL=postgresql://toxscreen:toxscreen_password@postgres:5432/toxscreen
POSTGRES_USER=toxscreen
POSTGRES_PASSWORD=toxscreen_password
POSTGRES_DB=toxscreen

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-random-string-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# API Keys (free sources)
PUBCHEM_API_KEY=optional
CHEMBL_API_KEY=optional

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage
BACKUP_DIR=./backups
DATA_DIR=./data

# Limits
FREE_TIER_DAILY_LIMIT=100
MAX_SMILES_LENGTH=5000
REQUEST_TIMEOUT_SECONDS=30
